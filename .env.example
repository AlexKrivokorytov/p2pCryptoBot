# ── Telegram ─────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
# (Optional) Redis for FSM state storage (fallback to memory if not set)
REDIS_URL=redis://localhost:6379/0

# ── License ───────────────────────────────────────────────────────────────────
# Your unique license key bound to this specific BOT_TOKEN.
# Obtain this from the seller after purchase. The bot will refuse to start
# without a valid key. Each key is mathematically tied to one bot token only.
LICENSE_KEY=your_license_key_here

# ── Crypto Pay ────────────────────────────────────────────────────────────────
CRYPTOPAY_TOKEN=your_cryptopay_token_here
# Secret used to verify Crypto Pay webhook HMAC-SHA256 signatures
CRYPTOPAY_CALLBACK_SECRET=your_cryptopay_callback_secret_here

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_URI=postgresql+asyncpg://p2pbot:password@localhost:5432/p2pbot

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256 key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
AES_KEY=your_64_char_hex_aes_key_here

# ── Exchange API keys (READ + TRADE only — NO WITHDRAW) ───────────────────────
EXCHANGE_RATE_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Bot config ────────────────────────────────────────────────────────────────
# Webhook host (for production webhook mode), leave empty for polling
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook/bot
WEBHOOK_PORT=8080

# Crypto Pay webhook path
CRYPTOPAY_WEBHOOK_PATH=/webhook/cryptopay

# ── Order settings ────────────────────────────────────────────────────────────
ORDER_TIMEOUT_SEC=1800
ORDER_MIN_AMOUNT_USDT=1.0
ORDER_MAX_AMOUNT_USDT=50000.0

# ── Admins (comma-separated Telegram user IDs) ────────────────────────────────
ADMIN_IDS=123456789,987654321



# ── B2B SaaS Settings ─────────────────────────────────────────────────────────
# Price of a white-label license in Telegram Stars (10000 = 100 XTR)
B2B_LICENSE_PRICE_STARS=10000
# Username of the master bot for spawning links
MASTER_BOT_USERNAME=p2p_master_bot
# Master TON wallet for B2B payments (Phase 4)
MASTER_TON_WALLET=EQ...
