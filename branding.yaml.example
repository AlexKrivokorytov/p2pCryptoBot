# branding.yaml.example — Copy this file to branding.yaml and customize.
# branding.yaml is listed in .gitignore and will NOT be committed to git.
# branding.yaml.example IS committed and acts as the template for buyers.
#
# No Python knowledge is required to customize your bot.
# Simply edit the values below and restart your Docker container:
#   docker compose restart bot
#
# ─────────────────────────────────────────────────────────────────────────────

bot:
  # The name of your exchange platform shown everywhere in the bot
  # (welcome messages, help text, order notifications, etc.)
  # Example: "MyExchange", "FastTrade", "CoinSwap"
  name: "P2P Exchange"

  # Message sent to users when they first start the bot (or type /start).
  # Available placeholders:
  #   {bot_name}   → replaced with the value of bot.name above
  #   {first_name} → replaced with the user's Telegram first name
  welcome_message: "👋 Welcome to {bot_name}, {first_name}!"

  # Telegram handle of your support account or group.
  # Shown in the help text and in error messages.
  # Example: "@MyBotSupport", "@MyExchangeHelp"
  support_handle: "@support"

  # Full help text displayed when a user taps the Help button.
  # Available placeholders:
  #   {support_handle} → replaced with the value of bot.support_handle above
  # HTML formatting is supported:
  #   <b>bold</b>, <i>italic</i>, <code>code</code>, <a href="url">link</a>
  # Use the | character to write multi-line text (YAML block scalar).
  help_text: |
    ℹ️ <b>How P2P works:</b>

    1️⃣ Create an order — choose asset, amount, and fiat currency.
    2️⃣ Pay the invoice via Crypto Pay — funds locked in escrow.
    3️⃣ Transfer fiat to the seller outside the bot.
    4️⃣ Seller confirms receipt → crypto released to you.
    5️⃣ Dispute? Open a case and a moderator will review.

    Questions? Contact {support_handle}

# ─────────────────────────────────────────────────────────────────────────────
ui:
  # Emojis displayed on the main menu buttons.
  # You can replace these with any emoji to match your brand style.
  create_ad_emoji: "📝"   # Button: "Create Ad"
  market_emoji: "🛒"       # Button: "P2P Market"
  trades_emoji: "📋"       # Button: "My Trades"
  profile_emoji: "👤"      # Button: "Profile"
  wallet_emoji: "💼"       # Button: "Wallets"
  dispute_emoji: "⚖️"      # Button: "Open Dispute" (shown inside active trades)
  escrow_emoji: "🔒"       # Indicator shown next to locked escrow amounts

# ─────────────────────────────────────────────────────────────────────────────
fees:
  # Fee charged to the user who creates the advertisement (the Maker).
  # This is a percentage of the total trade amount.
  # Example: 0.5 means 0.5% fee. Set to 0.0 for no maker fee.
  maker_percent: 0.0

  # Fee charged to the user who accepts an advertisement (the Taker).
  # This is a percentage of the total trade amount.
  # Example: 1.0 means 1% fee. Set to 0.0 for no taker fee.
  taker_percent: 0.0

  # A flat fee added to every trade on top of the percentage fees.
  # Expressed in the traded crypto asset's units.
  # Example: 0.001 for BTC means 0.001 BTC per trade regardless of amount.
  # Set to 0.0 for no fixed fee.
  fixed_fee: 0.0

# ─────────────────────────────────────────────────────────────────────────────
# Which crypto assets are available for trading on your platform.
# Remove lines for assets you do not want to support.
# Valid values: USDT, TON, BTC, ETH, USDC
# At least one asset must be enabled.
assets_enabled:
  - USDT
  - TON
  - BTC
  - ETH
  - USDC

# ─────────────────────────────────────────────────────────────────────────────
# Payment methods buyers and sellers can choose from when creating a trade.
# Add, remove, or rename entries to match your target market.
# These are free-form strings — any text is valid.
payment_methods:
  - "Sberbank"
  - "Tinkoff"
  - "Revolut"
  - "SWIFT"
  - "Cash"
  - "Other"

# ─────────────────────────────────────────────────────────────────────────────
limits:
  # Minimum trade size expressed in USDT equivalent.
  # Orders below this amount will be rejected.
  # Recommended: 1.0 (protects against dust/spam attacks).
  order_min_amount_usdt: 1.0

  # Maximum trade size expressed in USDT equivalent.
  # Orders above this amount will be rejected.
  # Adjust based on your KYC/AML policy and risk tolerance.
  # Example: 10000.0 for a lower-risk, lower-volume platform.
  order_max_amount_usdt: 50000.0

  # How long an unfunded order remains listed before automatic cancellation.
  # Value is in seconds. 1800 = 30 minutes.
  # Minimum recommended: 600 (10 minutes) to give buyers enough time.
  # Maximum recommended: 7200 (2 hours) to prevent stale order accumulation.
  order_timeout_sec: 1800

# ─────────────────────────────────────────────────────────────────────────────
notifications:
  # Templates for automated Telegram notifications.
  # Use HTML tags for formatting. Placeholders {order_id}, {asset}, {amount}, etc.
  
  # Sent to Maker when a Taker accepts their order.
  taker_found: |
    🔔 <b>Trade Started!</b>
    Order: <code>{order_id_short}</code>
    Taker: {taker_display}
    
    Your crypto is locked in escrow. Wait for the taker to send the fiat payment.
    You will receive another notification once they confirm the transfer.

  # Sent to Maker when Taker clicks "I've sent fiat".
  fiat_sent: |
    💸 <b>Fiat Transfer Confirmed by Taker!</b>
    Order: <code>{order_id_short}</code>
    
    Please check your bank account / wallet.
    If you received the exact amount, tap <b>Release Escrow</b>.
    If there is an issue, you can raise a dispute.

  # Sent to Taker when Maker releases escrow.
  escrow_released: |
    ✅ <b>Crypto Released!</b>
    Order: <code>{order_id_short}</code>
    Amount: <code>{amount} {asset}</code>
    
    The seller confirmed your fiat payment. 
    Your crypto has been transferred to your wallet.

  # Sent to both parties when a dispute is opened.
  dispute_opened: |
    ⚠️ <b>Dispute Opened</b>
    Order: <code>{order_id_short}</code>
    Reason: <i>{reason}</i>
    
    A moderator will review the trade history and make a decision. 
    The funds are locked in escrow until the dispute is resolved.

  # Sent to both parties when a dispute is resolved.
  dispute_resolved: |
    ⚖️ <b>Dispute Resolved</b>
    Order: <code>{order_id_short}</code>
    Decision: <b>{decision}</b>
    
    Status: <b>{status}</b>
    The moderator has made a final decision on this trade.

  # Sent to Maker when an ad expires or is cancelled.
  order_expired: |
    ⏰ <b>Ad Expired / Cancelled</b>
    Order: <code>{order_id_short}</code>
    Asset: <b>{asset}</b>
    
    Your ad was cancelled or timed out.
    If funds were in escrow, they have been returned to your wallet.

  # Sent to Maker when funds are refunded (e.g. dispute won or manual cancel).
  escrow_refunded: |
    💰 <b>Escrow Refunded</b>
    Order: <code>{order_id_short}</code>
    Amount: <code>{amount} {asset}</code>
    
    The crypto has been returned to your wallet.
